<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#FFFFFF"
    android:orientation="vertical"
    android:padding="24dp"
    tools:context=".MainActivity">

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:fontFamily="sans-serif-black"
        android:text="SensorApp"
        android:textColor="#000000"
        android:textSize="40sp"
        android:letterSpacing="-0.02" />

    <View
        android:layout_width="60dp"
        android:layout_height="4dp"
        android:layout_marginTop="12dp"
        android:background="#000000" />

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_marginTop="32dp"
        android:layout_weight="1"
        android:scrollbars="none">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:fontFamily="sans-serif-black"
                android:text="GŁÓWNE"
                android:textColor="#CCCCCC"
                android:textSize="11sp"
                android:letterSpacing="0.15" />

            <TextView
                android:id="@+id/tv_light"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:fontFamily="sans-serif-medium"
                android:text="Światło: --"
                android:textColor="#000000"
                android:textSize="18sp" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Mierzy natężenie światła (lux). TEST: Zakryj dłonią górę ekranu."
                android:textColor="#888888"
                android:textSize="11sp" />

            <TextView
                android:id="@+id/tv_gyro"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:fontFamily="sans-serif-medium"
                android:text="Żyroskop: --"
                android:textColor="#000000"
                android:textSize="18sp" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Mierzy prędkość obrotową (rad/s). TEST: Obracaj telefonem."
                android:textColor="#888888"
                android:textSize="11sp" />

            <TextView
                android:id="@+id/tv_accel"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:fontFamily="sans-serif-medium"
                android:text="Akcelerometr: --"
                android:textColor="#000000"
                android:textSize="18sp" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Mierzy przyspieszenie (m/s²). TEST: Potrząśnij telefonem."
                android:textColor="#888888"
                android:textSize="11sp" />

            <TextView
                android:id="@+id/tv_steps"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:fontFamily="sans-serif-medium"
                android:text="Licznik kroków: --"
                android:textColor="#000000"
                android:textSize="18sp" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Zlicza kroki od restartu. TEST: Przejdź się z telefonem."
                android:textColor="#888888"
                android:textSize="11sp" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="40dp"
                android:fontFamily="sans-serif-black"
                android:text="DODATKOWE"
                android:textColor="#CCCCCC"
                android:textSize="11sp"
                android:letterSpacing="0.15" />

            <TextView
                android:id="@+id/tv_vector"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:fontFamily="sans-serif-medium"
                android:text="Wektor rotacji: --"
                android:textColor="#000000"
                android:textSize="14sp" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Orientacja w przestrzeni 3D. TEST: Wykonuj ruchy sferyczne."
                android:textColor="#888888"
                android:textSize="11sp" />

            <TextView
                android:id="@+id/tv_mag"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:fontFamily="sans-serif-medium"
                android:text="Magnetometr: --"
                android:textColor="#000000"
                android:textSize="14sp" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Pole magnetyczne (μT). TEST: Zbliż do metalu lub magnesu."
                android:textColor="#888888"
                android:textSize="11sp" />

            <TextView
                android:id="@+id/tv_orientation"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:fontFamily="sans-serif-medium"
                android:text="Orientacja: --"
                android:textColor="#000000"
                android:textSize="14sp" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Kąty nachylenia urządzenia. TEST: Użyj jako poziomicy."
                android:textColor="#888888"
                android:textSize="11sp" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="40dp"
                android:fontFamily="sans-serif-black"
                android:text="STRUMIEŃ DANYCH"
                android:textColor="#CCCCCC"
                android:textSize="11sp"
                android:letterSpacing="0.15" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:orientation="vertical"
                android:background="#F8F8F8"
                android:padding="16dp">

                <TextView android:id="@+id/tv_light_lower" android:layout_width="match_parent" android:layout_height="wrap_content" android:fontFamily="monospace" android:text="ŚWIATŁO: --" android:textColor="#222222" android:textSize="12sp" />
                <TextView android:id="@+id/tv_accel_lower" android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginTop="6dp" android:fontFamily="monospace" android:text="Akcelometr: --" android:textColor="#222222" android:textSize="12sp" />
                <TextView android:id="@+id/tv_gyro_lower" android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginTop="6dp" android:fontFamily="monospace" android:text="ŻYROSKOP: --" android:textColor="#222222" android:textSize="12sp" />
                <TextView android:id="@+id/tv_mag_lower" android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginTop="6dp" android:fontFamily="monospace" android:text="Pole Magnetyczne: --" android:textColor="#222222" android:textSize="12sp" />
                <TextView android:id="@+id/tv_linear_lower" android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginTop="6dp" android:fontFamily="monospace" android:text="PRZYŚPIESZENIE LINIOWE: --" android:textColor="#222222" android:textSize="12sp" />
                <TextView android:id="@+id/tv_grav_lower" android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginTop="6dp" android:fontFamily="monospace" android:text="GRAWITACJA: --" android:textColor="#222222" android:textSize="12sp" />
                <TextView android:id="@+id/tv_proximity_lower" android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginTop="6dp" android:fontFamily="monospace" android:text="Zbliżeniowy: --" android:textColor="#222222" android:textSize="12sp" />
                <TextView android:id="@+id/tv_orientation_lower" android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginTop="6dp" android:fontFamily="monospace" android:text="ORIENTACJA: --" android:textColor="#222222" android:textSize="12sp" />
                <TextView android:id="@+id/tv_significant_lower" android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginTop="6dp" android:fontFamily="monospace" android:text="Significant: --" android:textColor="#222222" android:textSize="12sp" />
                <TextView android:id="@+id/tv_step_detector_lower" android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginTop="6dp" android:fontFamily="monospace" android:text="Czujnik kroków: --" android:textColor="#222222" android:textSize="12sp" />
                <TextView android:id="@+id/tv_step_counter_lower" android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginTop="6dp" android:fontFamily="monospace" android:text="Licznik kroków: --" android:textColor="#222222" android:textSize="12sp" />

            </LinearLayout>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="40dp"
                android:fontFamily="sans-serif-black"
                android:text="WYKAZ SPRZĘTU"
                android:textColor="#CCCCCC"
                android:textSize="11sp"
                android:letterSpacing="0.15" />

            <ListView
                android:id="@+id/sensor_list"
                android:layout_width="match_parent"
                android:layout_height="300dp"
                android:layout_marginTop="12dp"
                android:divider="#EEEEEE"
                android:dividerHeight="1dp"
                android:scrollbars="none" />

        </LinearLayout>
    </ScrollView>

</LinearLayout>
